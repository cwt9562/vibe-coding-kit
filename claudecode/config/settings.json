{
  "alwaysThinkingEnabled": true,
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "defaultShell": "bash",
  "effortLevel": "xhigh",
  "env": {
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1",
    "CLAUDE_CODE_WORKFLOWS": "1"
  },
  "expandThinking": true,
  "includeCoAuthoredBy": false,
  "language": "chinese",
  "model": "opus",
  "showThinkingSummaries": true,
  "skillOverrides": {
    "agent-browser": "name-only",
    "ascii-art-diagrams": "user-invocable-only",
    "caveman": "on",
    "chinese-code-review": "user-invocable-only",
    "chinese-documentation": "name-only",
    "commit": "user-invocable-only",
    "docx": "user-invocable-only",
    "frontend-ascii-previewer": "name-only",
    "frontend-ui-ux": "name-only",
    "humanizer": "on",
    "mermaid-tools": "name-only",
    "pdf": "user-invocable-only",
    "pptx": "user-invocable-only",
    "pull": "user-invocable-only",
    "push": "user-invocable-only",
    "tdd": "user-invocable-only",
    "to-issues": "user-invocable-only",
    "to-prd": "user-invocable-only",
    "weeklog": "user-invocable-only",
    "write-readme": "user-invocable-only",
    "xlsx": "user-invocable-only"
  },
  "skipDangerousModePermissionPrompt": true,
  "skipWebFetchPreflight": true,
  "tui": "fullscreen"
}